# Copiar este archivo a .env y completar con los valores reales.
# .env está en .gitignore — nunca commitear secrets.

# =============================================================================
# BASE DE DATOS (PostgreSQL en Docker)
# Levantar con: ./start-database.sh (desde WSL)
# =============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/app_menu"

# =============================================================================
# AUTH (NextAuth v5)
# Generar con: npx auth secret  o  openssl rand -base64 32
# =============================================================================
AUTH_SECRET="reemplazar-con-valor-generado"

# =============================================================================
# SUPABASE STORAGE
# Obtener desde: supabase.com → Settings → API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# =============================================================================
# MERCADO PAGO
# Obtener desde: mercadopago.com.ar/developers → Tus integraciones
# En desarrollo usar credenciales de SANDBOX (TEST)
# =============================================================================
MP_ACCESS_TOKEN="APP_USR-xxxx"
MP_WEBHOOK_SECRET=""

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
